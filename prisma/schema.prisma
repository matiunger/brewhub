// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Equipment {
  id                       String   @id @default(uuid())
  name                     String
  brewhouseEfficiency      Float    @map("brewhouse_efficiency")
  mashEfficiency           Float?   @map("mash_efficiency")
  mashTunVolumeL           Float?   @map("mash_tun_volume_l")
  mashTunDeadSpaceL        Float?   @map("mash_tun_dead_space_l")
  boilPotVolumeL           Float?   @map("boil_pot_volume_l")
  boilPotDiameter          Float?   @map("boil_pot_diameter")
  boilEvaporationRateLH    Float?   @map("boil_evaporation_rate_l_h")
  heatingEvaporationRateLH Float?   @map("heating_evaporation_rate_l_h")
  spargeWaterPotDiameter   Float?   @map("sparge_water_pot_diameter")
  grainAbsorptionLKg       Float?   @map("grain_absorption_l_kg")
  fermenterLossL           Float    @map("fermenter_loss_l")
  trubLossL                Float    @map("trub_loss_l")
  systemLossPercent        Float?   @map("system_loss_percent")
  tempContractionPercent   Float?   @map("temp_contraction_percent") @default(4)
  batches                  Batch[]

  @@map("equipment")
}

model Grain {
  id          String         @id @default(uuid())
  name        String
  type        String?        // BeerJSON: dry extract, extract, grain, sugar, fruit, juice, honey, other
  origin      String?
  grainGroup  String?        @map("grain_group") // BeerJSON grain_group: base, caramel, flaked, roasted, specialty, smoked, adjunct
  brand       String?
  maxYield    Float?         @map("max_yield")
  colorL      Float?         @map("color_l")
  profile     String?
  uses        String?
  batchGrains BatchGrain[]

  @@map("grains")
}

model Hop {
  id          String         @id @default(uuid())
  name        String
  origin      String?
  form        String?        // BeerJSON: extract, leaf, leaf (wet), pellet, powder, plug
  hopType     String?        @map("hop_type") // BeerJSON type: aroma, bittering, flavor, aroma/bittering, bittering/flavor, aroma/flavor, aroma/bittering/flavor
  alphaAcid   Float          @map("alpha_acid")
  betaAcid    Float?         @map("beta_acid")
  profile     String?
  styles      String?
  alternatives String?
  batchHops   BatchHop[]

  @@map("hops")
}

model Yeast {
  id               String         @id @default(uuid())
  name             String
  brand            String?
  type             String?        // BeerJSON form: liquid, dry, slant, culture, dregs
  cultureType      String?        @map("culture_type") // BeerJSON type: ale, bacteria, brett, champagne, kveik, lacto, lager, malolactic, mixed-culture, other, pedio, spontaneous, wine
  temperatureRange String?        @map("temperature_range")
  profile          String?
  uses             String?
  attenuation      Float?
  batchYeasts      BatchYeast[]

  @@map("yeasts")
}

model WaterProfile {
  id          String         @id @default(uuid())
  name        String
  caPpm       Float          @map("ca_ppm")
  mgPpm       Float          @map("mg_ppm")
  naPpm       Float          @map("na_ppm")
  clPpm       Float          @map("cl_ppm")
  so4Ppm      Float          @map("so4_ppm")
  znPpm       Float?         @map("zn_ppm")
  hco3Ppm     Float?         @map("hco3_ppm")
  pH          Float?         @map("ph")
  sourceBatches Batch[]      @relation("SourceWaterProfile")
  targetBatches Batch[]      @relation("TargetWaterProfile")

  @@map("water_profiles")
}

model Keg {
  id           String  @id @default(uuid())
  name         String
  type         String?
  label        String?
  capacity     Float
  tareWeight   Float?  @map("tare_weight")
  notes        String?

  @@map("kegs")
}

model Batch {
  id                    String      @id @default(uuid())
  brewDate              DateTime?   @map("brew_date")
  type                  String      // beer, cider, hopwater, other
  name                  String
  style                 String?
  notes                 String?
  draft                 Boolean     @default(true)
  targetFermentarL      Float?      @map("target_fermentar_l")
  targetOg              Float?      @map("target_og")
  targetFg              Float?      @map("target_fg")
  targetIbu             Float?      @map("target_ibu")
  targetSrm             Float?      @map("target_srm")
  
  equipment             Equipment?  @relation(fields: [equipmentId], references: [id])
  equipmentId           String?     @map("equipment_id")
  
  sourceWaterProfile    WaterProfile? @relation("SourceWaterProfile", fields: [sourceWaterProfileId], references: [id])
  sourceWaterProfileId  String?       @map("source_water_profile_id")
  
  targetWaterProfile    WaterProfile? @relation("TargetWaterProfile", fields: [targetWaterProfileId], references: [id])
  targetWaterProfileId  String?       @map("target_water_profile_id")
  
  heatUpTimeMin         Float?        @map("heat_up_time_min")
  boilTimeMin           Float?        @map("boil_time_min")
  whirpoolTimeMin       Float?        @map("whirpool_time_min")

  grainTempC            Float?        @map("grain_temp_c")
  targetPh              Float?        @map("target_ph")
  spargeTargetPh        Float?        @map("sparge_target_ph")

  saltChalkGL       Float?  @map("salt_chalk_gl")
  saltBakingSodaGL  Float?  @map("salt_baking_soda_gl")
  saltGypsumGL      Float?  @map("salt_gypsum_gl")
  saltCaCl2GL       Float?  @map("salt_ca_cl2_gl")
  saltEpsomGL       Float?  @map("salt_epsom_gl")
  saltNaClGL        Float?  @map("salt_na_cl_gl")

  sourceCaPpm       Float?  @map("source_ca_ppm")
  sourceMgPpm       Float?  @map("source_mg_ppm")
  sourceNaPpm       Float?  @map("source_na_ppm")
  sourceClPpm       Float?  @map("source_cl_ppm")
  sourceSo4Ppm      Float?  @map("source_so4_ppm")
  sourceZnPpm       Float?  @map("source_zn_ppm")
  sourceHco3Ppm     Float?  @map("source_hco3_ppm")
  sourceWaterPh     Float?  @map("source_water_ph")

  targetCaPpm       Float?  @map("target_ca_ppm")
  targetMgPpm       Float?  @map("target_mg_ppm")
  targetNaPpm       Float?  @map("target_na_ppm")
  targetClPpm       Float?  @map("target_cl_ppm")
  targetSo4Ppm      Float?  @map("target_so4_ppm")
  targetZnPpm       Float?  @map("target_zn_ppm")
  targetHco3Ppm     Float?  @map("target_hco3_ppm")
  targetWaterPh     Float?  @map("target_water_ph")
   
  brewdayData           String?               @map("brewday_data")

  // Equipment snapshot — copied from inventory when equipment is selected, editable per-batch
  equipmentName              String?  @map("equipment_name")
  equipmentBrewhouseEff      Float?   @map("equipment_brewhouse_eff")
  equipmentMashEff           Float?   @map("equipment_mash_eff")
  equipmentMashTunVolumeL    Float?   @map("equipment_mash_tun_volume_l")
  equipmentMashTunDeadSpaceL Float?   @map("equipment_mash_tun_dead_space_l")
  equipmentBoilPotVolumeL    Float?   @map("equipment_boil_pot_volume_l")
  equipmentBoilEvapRateLH    Float?   @map("equipment_boil_evap_rate_l_h")
  equipmentHeatEvapRateLH    Float?   @map("equipment_heat_evap_rate_l_h")
  equipmentGrainAbsLKg       Float?   @map("equipment_grain_abs_l_kg")
  equipmentFermenterLossL    Float?   @map("equipment_fermenter_loss_l")
  equipmentTrubLossL         Float?   @map("equipment_trub_loss_l")
  equipmentSystemLossPct     Float?   @map("equipment_system_loss_pct")
  equipmentTempContractionPct Float?  @map("equipment_temp_contraction_pct")

  grains                BatchGrain[]
  hops                  BatchHop[]
  yeasts                BatchYeast[]
  mashSteps             MashStep[]

  @@map("batches")
}

model BatchGrain {
  id         String   @id @default(uuid())
  batch      Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId    String   @map("batch_id")
  grain      Grain    @relation(fields: [grainId], references: [id])
  grainId    String   @map("grain_id")
  grams      Float
  // Snapshot fields — copied from inventory at add time, editable per batch
  name       String?
  brand      String?
  colorL     Float?   @map("color_l")
  maxYield   Float?   @map("max_yield")
  grainGroup String?  @map("grain_group")

  @@map("batch_grains")
}

model BatchHop {
  id           String   @id @default(uuid())
  batch        Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId      String   @map("batch_id")
  hop          Hop      @relation(fields: [hopId], references: [id])
  hopId        String   @map("hop_id")
  grams        Float
  additionTime Float    @map("addition_time") // minutes
  use          String   // fwh, boil, whirlpool, hop_stand, dry_hop
  // Snapshot fields
  name         String?
  alphaAcid    Float?   @map("alpha_acid")

  @@map("batch_hops")
}

model BatchYeast {
  id             String   @id @default(uuid())
  batch          Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId        String   @map("batch_id")
  yeast          Yeast    @relation(fields: [yeastId], references: [id])
  yeastId        String   @map("yeast_id")
  quantity       String?
  quantityAmount Float?   @map("quantity_amount")
  quantityUnits  String?  @map("quantity_units")
  temp           Float?
  // Snapshot fields
  name           String?
  brand          String?
  attenuation    Float?

  @@map("batch_yeasts")
}

model MashStep {
  id                String   @id @default(uuid())
  batch             Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId           String   @map("batch_id")
  name              String
  type              String   // infusion, temperature, decoction, souring mash, souring wort, drain mash tun, sparge
  stepTemperatureC  Float    @map("step_temperature_c")
  stepTimeMin       Float    @map("step_time_min")
  amountL           Float?   @map("amount_l")
  rampTimeMin       Float?   @map("ramp_time_min")
  endTemperatureC   Float?   @map("end_temperature_c")
  description       String?
  infuseTemperatureC Float?  @map("infuse_temperature_c")
  sortOrder         Int      @default(0) @map("sort_order")

  @@map("mash_steps")
}

model WikiPage {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("wiki_pages")
}
